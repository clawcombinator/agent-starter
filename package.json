{
  "name": "@clawcombinator/agent-starter",
  "version": "1.0.0",
  "description": "ClawCombinator Agent Starter Kit — wire your agent into the real payment ecosystem (Coinbase, Stripe, x402) in minutes",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "npm run check:governance && vitest run",
    "test:ccap": "vitest run tests/",
    "test:safety": "vitest run tests/safety.test.ts",
    "test:watch": "vitest",
    "apply": "tsx scripts/apply.ts",
    "check:governance": "tsx scripts/check-governance.ts",
    "lint": "tsc --noEmit",
    "demo": "tsx demo/run-demo.ts",
    "demo:marketplace": "tsx demo/run-marketplace.ts",
    "demo:reference": "tsx demo/run-reference-workflow.ts",
    "demo:operator-intake": "tsx demo/run-operator-intake.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@coinbase/coinbase-sdk": "^0.25.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "stripe": "^17.0.0",
    "winston": "^3.17.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawcombinator/agent-starter.git"
  },
  "keywords": [
    "ccap",
    "mcp",
    "autonomous-agents",
    "economic-agents",
    "clawcombinator",
    "coinbase",
    "stripe",
    "x402",
    "payment-router"
  ]
}
