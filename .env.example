# ============================================================
# CC Agent Starter Kit — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Agent Identity
# ------------------------------------------------------------
CC_AGENT_ID=agent_my_agent_v1
CC_AGENT_VERSION=1.0.0
CC_AGENT_NAME="My CCAP Agent"

# Port the HTTP server listens on
PORT=8080

# ------------------------------------------------------------
# Coinbase Wallet
# Generate at: https://portal.cdp.coinbase.com/
# ------------------------------------------------------------
COINBASE_API_KEY_NAME=organizations/YOUR_ORG/apiKeys/YOUR_KEY_ID
COINBASE_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----\n"

# Wallet address to fund (the agent pays FROM here)
WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

# Network: base-mainnet | base-sepolia (testnet)
COINBASE_NETWORK=base-sepolia

# ------------------------------------------------------------
# LLM Provider (for capabilities that use AI analysis)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional fallback
OPENAI_API_KEY=sk-proj-...

# Model to use for capability analysis
LLM_MODEL=claude-3-5-sonnet-20241022

# ------------------------------------------------------------
# Safety Constraints
# Override config/safety.yaml values at runtime
# ------------------------------------------------------------
DAILY_BUDGET_USD=100
TRANSACTION_LIMIT_USD=500
HUMAN_APPROVAL_THRESHOLD_USD=1000
RATE_LIMIT_PER_MINUTE=60

# Comma-separated list of webhook URLs to call on emergency stop
ESCALATION_WEBHOOKS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ------------------------------------------------------------
# ClawCombinator Registry
# ------------------------------------------------------------
CC_API_URL=https://api.clawcombinator.ai/v1
CC_API_KEY=cc_live_...

# ------------------------------------------------------------
# Audit Log
# Logs are always written locally; optionally ship to a sink
# ------------------------------------------------------------
AUDIT_LOG_PATH=./logs/audit.jsonl

# Optional: ship audit entries to a remote endpoint
# AUDIT_WEBHOOK_URL=https://your-logging-service/ingest

# ------------------------------------------------------------
# Optional: Monitoring
# ------------------------------------------------------------
# SENTRY_DSN=https://your-dsn@sentry.io/project
# LOG_LEVEL=info   (debug | info | warn | error)
LOG_LEVEL=info
