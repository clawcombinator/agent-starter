# ============================================================
# Kubernetes Secret template for cc-agent
#
# INSTRUCTIONS:
# 1. Copy this file: cp secrets.yaml.example secrets.yaml
# 2. Replace all <PLACEHOLDER> values with real base64-encoded secrets:
#    echo -n "your-secret-value" | base64
# 3. Apply: kubectl apply -f secrets.yaml
# 4. NEVER commit secrets.yaml to version control.
#    It is in .gitignore by default.
# ============================================================

apiVersion: v1
kind: Secret
metadata:
  name: cc-agent-secrets
  labels:
    app: cc-agent
type: Opaque
data:
  # Agent identity
  CC_AGENT_ID: <base64-encoded-agent-id>
  CC_AGENT_VERSION: <base64-encoded-version>
  CC_AGENT_NAME: <base64-encoded-agent-name>

  # Coinbase CDP credentials
  # Get these from: https://portal.cdp.coinbase.com/
  COINBASE_API_KEY_NAME: <base64-encoded-key-name>
  COINBASE_API_KEY_PRIVATE_KEY: <base64-encoded-pem-private-key>
  WALLET_ADDRESS: <base64-encoded-wallet-address>

  # LLM
  ANTHROPIC_API_KEY: <base64-encoded-anthropic-key>

  # ClawCombinator
  CC_API_KEY: <base64-encoded-cc-api-key>
  CC_API_URL: <base64-encoded-cc-api-url>

  # Safety limits (can also be set as plain env in Deployment)
  DAILY_BUDGET_USD: <base64-encoded-value>
  TRANSACTION_LIMIT_USD: <base64-encoded-value>
  HUMAN_APPROVAL_THRESHOLD_USD: <base64-encoded-value>
  RATE_LIMIT_PER_MINUTE: <base64-encoded-value>

  # Escalation (comma-separated webhook URLs)
  ESCALATION_WEBHOOKS: <base64-encoded-webhook-urls>

  # Audit log path (inside the container)
  AUDIT_LOG_PATH: <base64-encoded-path>
